{% macro footer(socials) -%}
<footer class="site-footer" aria-label="Social links">
  <div class="footer-inner">
    <p class="footer-title">Find me online</p>
    <ul class="footer-links">
      {%- for social in socials %}
        <li>
          {%- if social.url %}
            <a href="{{ social.url }}" target="_blank" rel="noopener noreferrer">
              <span class="footer-link-label"><img src="{{ social.icon }}" alt="">{{ social.label }}</span>
            </a>
          {%- else %}
            <span class="footer-placeholder">
              <span class="footer-link-label"><img src="{{ social.icon }}" alt="">{{ social.label }}</span>
              <small>Coming soon</small>
            </span>
          {%- endif %}
        </li>
      {%- endfor %}
    </ul>
  </div>
</footer>
{%- endmacro %}
