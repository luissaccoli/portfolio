{% macro navbar(languages, current_lang, copy) -%}
<nav class="glass-nav" aria-label="{{ copy.label }}">
  <a class="nav-link" href="#title">{{ copy.about }}</a>

  <details class="language-menu">
    <summary>{{ copy.language }}</summary>
    <div class="language-options">
      {%- for language in languages %}
        <a href="{{ language.href }}"{% if language.code == current_lang %} aria-current="page"{% endif %}>
          {{ language.label }}
        </a>
      {%- endfor %}
    </div>
  </details>

  <a class="nav-link nav-cta" href="#book-a-call">{{ copy.bookCall }}</a>
</nav>
{%- endmacro %}
